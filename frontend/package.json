{
  "name": "workflow-ui5-tester",
  "version": "0.0.1",
  "description": "UI5 Workflow API Tester for Spring Boot Backend",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "eslint": "^10",
    "ui5-middleware-simpleproxy": "^3.7.1"
  },
  "scripts": {
    "start": "npx -p @ui5/cli ui5 serve --config=ui5.yaml --port 8080 --open index.html",
    "build": "npx -p @ui5/cli ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "zip": "cd dist && zip -r ../com.workflow.ui5.zip . && cd ..",
    "build:mta": "npm run build && npm run zip"
  },
  "sapuxLayer": "CUSTOMER_BASE",
  "sapux": true
}