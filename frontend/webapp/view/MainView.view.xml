<mvc:View
    controllerName="com.workflow.ui5.controller.MainController"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    height="100%">
    
    <Page
        id="pageMain"
        title="Procurement Workflow - Payment Request Approval"
        showNavButton="false"
        enableScrolling="true"
        class="sapUiContentPadding">
        
        <content>
            <l:Grid id="gridMain" class="sapUiSmallMargin" width="100%">
                <!-- Left Column -->
                <l:Grid id="gridLeftColumn" defaultSpan="L6 M12 S12" class="sapUiSmallMarginEnd">
                    <content>
                        <!-- Payment Request Details Card -->
                        <Panel
                            id="panelPaymentDetails"
                            expandable="false"
                            class="sapUiSmallMarginBottom"
                            headerText="📄 Payment Request Details"
                            headerLevel="H3">
                            <content>
                                <f:SimpleForm
                                    id="formPaymentDetails"
                                    editable="false"
                                    layout="ResponsiveGridLayout"
                                    labelSpanL="4"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    class="sapUiSmallMargin">
                                    <f:content>
                                        <Label text="Request ID" design="Bold"/>
                                        <Text id="textRequestId" text="{workflow>/requestId}"/>
                                        
                                        <Label text="Classification" design="Bold"/>
                                        <Text text="{workflow>/classification}"/>
                                        
                                        <Label text="Workflow Amount" design="Bold"/>
                                        <Text id="textAmount" text="{workflow>/amount}" class="sapUiSmallMarginBottom"/>
                                        
                                        <Label text="Due Date" design="Bold"/>
                                        <Text text="{workflow>/dueDate}"/>
                                        
                                        <Label text="Payment Request Date" design="Bold"/>
                                        <Text text="{workflow>/paymentDate}"/>
                                        
                                        <Label text="Status" design="Bold"/>
                                                        <ObjectStatus id="workflowStatus" state="{workflow>/statusState}" text="{workflow>/workflowStatus}"/>
                                    </f:content>
                                </f:SimpleForm>
                            </content>
                        </Panel>

                        <!-- Approval Flow Card -->
                        <Panel
                            id="panelApprovalFlow"
                            expandable="false"
                            class="sapUiSmallMarginBottom"
                            headerText="✅ Approval Flow &amp; Step Progress"
                            headerLevel="H3">
                            <content>
                                <VBox class="sapUiSmallMargin">
                                    <!-- Workflow Steps Visualization -->
                                    <HBox id="workflowStepsContainer" class="sapUiSmallMarginBottom" wrap="Wrap" justifyContent="Center"/>
                                    
                                    <!-- Current Step Info -->
                                    <f:SimpleForm
                                        id="formCurrentStep"
                                        layout="ResponsiveGridLayout"
                                        labelSpanL="4"
                                        labelSpanM="4"
                                        labelSpanS="12"
                                        class="sapUiSmallMarginTop">
                                        <f:content>
                                            <Label text="Current Step" design="Bold"/>
                                            <Text id="currentStepLabel" text="{workflow>/currentStep/levelName}"/>
                                            
                                            <Label text="Current Approver" design="Bold"/>
                                            <Text id="currentApproverLabel" text="{workflow>/currentApprover}"/>
                                            
                                            <Label text="Total Progress" design="Bold"/>
                                            <ProgressIndicator
                                                id="progressIndicator"
                                                percentValue="{workflow>/progressPercent}"
                                                showValue="true"
                                                class="sapUiSmallMarginTop"/>
                                        </f:content>
                                    </f:SimpleForm>
                                </VBox>
                            </content>
                        </Panel>

                        <!-- Actions Card -->
                        <Panel
                            id="panelActions"
                            expandable="false"
                            expanded="true"
                            headerText="🎯 Workflow Actions"
                            headerLevel="H3">
                            <content>
                                <VBox class="sapUiSmallMargin">
                                    <!-- Action Buttons -->
                                    <HBox id="actionButtonsContainer" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                        <Button
                                            id="btnApprove"
                                            text="APPROVE"
                                            type="Accept"
                                            icon="sap-icon://accept"
                                            press="onApprove"
                                            enabled="{workflow>/canApprove}"
                                            class="sapUiSmallMarginEnd"/>
                                        <Button
                                            id="btnReject"
                                            text="REJECT"
                                            type="Reject"
                                            icon="sap-icon://decline"
                                            press="onReject"
                                            enabled="{workflow>/canReject}"
                                            class="sapUiSmallMarginEnd"/>
                                        <Button
                                            id="btnReturn"
                                            text="RETURN"
                                            icon="sap-icon://undo"
                                            press="onReturn"
                                            enabled="{workflow>/canReturn}"/>
                                    </HBox>
                                    
                                    <HBox id="actionButtonsContainer2" justifyContent="SpaceBetween">
                                        <Button
                                            id="btnReassign"
                                            text="REASSIGN"
                                            icon="sap-icon://user-edit"
                                            press="onReassign"
                                            enabled="{workflow>/canReassign}"
                                            class="sapUiSmallMarginEnd"/>
                                        <Button
                                            id="btnOnHold"
                                            text="ON HOLD"
                                            icon="sap-icon://pause"
                                            press="onOnHold"
                                            enabled="{workflow>/canHold}"
                                            class="sapUiSmallMarginEnd"/>
                                    </HBox>

                                    <!-- Comment Area -->
                                    <Label text="Comment" design="Bold" class="sapUiSmallMarginTop"/>
                                    <TextArea
                                        id="commentArea"
                                        rows="3"
                                        width="100%"
                                        placeholder="Enter your comment here..."
                                        value="{workflow>/comment}"/>
                                </VBox>
                            </content>
                        </Panel>
                    </content>
                </l:Grid>

                <!-- Right Column - Response Console -->
                <l:Grid id="gridRightColumn" defaultSpan="L6 M12 S12">
                    <content>
                        <Panel
                            id="panelConsole"
                            expandable="true"
                            expanded="true"
                            headerText="📋 Response Console"
                            headerLevel="H3"
                            class="sapUiSmallMarginBottom">
                            <content>
                                <VBox class="sapUiSmallMargin">
                                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                                        <Label text="API Status" design="Bold"/>
                                        <ObjectStatus id="consoleStatus" state="{console>/statusState}" text="{console>/statusText}"/>
                                    </HBox>
                                    
                                    <TextArea
                                        id="consoleOutput"
                                        rows="20"
                                        width="100%"
                                        editable="false"
                                        value="{console>/output}"
                                        class="sapUiSmallMarginTop consoleMonospace"/>
                                    
                                    <Button
                                        id="btnClearConsole"
                                        text="Clear Console"
                                        icon="sap-icon://clear"
                                        press="onClearConsole"
                                        class="sapUiSmallMarginTop"/>
                                    
                                    <Button
                                        id="btnRefresh"
                                        text="Refresh Workflow"
                                        icon="sap-icon://refresh"
                                        press="onRefresh"
                                        type="Transparent"
                                        class="sapUiSmallMarginTop"/>
                                </VBox>
                            </content>
                        </Panel>
                    </content>
                </l:Grid>
            </l:Grid>
        </content>
        
        <!-- Return Dialog -->
        <Dialog
            id="returnDialog"
            title="Select Return Destination"
            contentWidth="500px"
            resizable="true"
            draggable="true">
            <content>
                <VBox class="sapUiSmallMargin">
                    <Label text="Select where to return the workflow:" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Select
                        id="returnStepSelect"
                        width="100%"
                        class="sapUiSmallMarginBottom"
                        placeholder="Choose a step to return to"/>
                    <Label text="Return Comment" design="Bold" class="sapUiSmallMarginTop"/>
                    <TextArea
                        id="returnComment"
                        rows="2"
                        width="100%"
                        placeholder="Reason for returning..."/>
                </VBox>
            </content>
            <beginButton>
                <Button text="Confirm Return" type="Emphasized" press="onConfirmReturn"/>
            </beginButton>
            <endButton>
                <Button text="Cancel" press="onCloseReturnDialog"/>
            </endButton>
        </Dialog>
        
        <!-- Reassign Dialog -->
        <Dialog
            id="reassignDialog"
            title="Reassign Task"
            contentWidth="450px"
            resizable="true"
            draggable="true">
            <content>
                <VBox class="sapUiSmallMargin">
                    <Label text="Select new approver:" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Select
                        id="reassignSelect"
                        width="100%"
                        class="sapUiSmallMarginBottom"
                        placeholder="Choose an approver"/>
                    <Label text="Reassignment Reason" design="Bold" class="sapUiSmallMarginTop"/>
                    <TextArea
                        id="reassignComment"
                        rows="2"
                        width="100%"
                        placeholder="Reason for reassignment..."/>
                </VBox>
            </content>
            <beginButton>
                <Button text="Confirm Reassign" type="Emphasized" press="onConfirmReassign"/>
            </beginButton>
            <endButton>
                <Button text="Cancel" press="onCloseReassignDialog"/>
            </endButton>
        </Dialog>
        
        <!-- Loading Dialog -->
        <Dialog id="loadingDialog" title="Processing" contentWidth="300px">
            <content>
                <VBox class="sapUiSmallMargin" alignItems="Center">
                    <BusyIndicator size="3rem" class="sapUiSmallMarginBottom"/>
                    <Text text="Processing workflow action..."/>
                </VBox>
            </content>
        </Dialog>
    </Page>
</mvc:View>