{
    "_version": "1.12.0",
    "sap.app": {
        "id": "com.workflow.ui5",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "title": "{{appTitle}}",
        "description": "Procurement Workflow UI5 Application",
        "version": "1.0.0"
    },
    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "com.workflow.ui5.view.MainView",
            "type": "XML",
            "async": true,
            "id": "app"
        },
        "dependencies": {
            "minUI5Version": "1.84.0",
            "libs": {
                "sap.ui.core": {},
                "sap.m": {},
                "sap.ui.layout": {}
            }
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.workflow.ui5.i18n.i18n"
                }
            }
        }
    },
    "sap.bpa": {
        "outcomes": {
            "APPROVE": {
                "title": "Approve"
            },
            "REJECT": {
                "title": "Reject"
            },
            "RETURN": {
                "title": "Return"
            },
            "REASSIGN": {
                "title": "Reassign"
            },
            "ON_HOLD": {
                "title": "On Hold"
            }
        }
    }
}