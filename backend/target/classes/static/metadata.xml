<?xml version="1.0" encoding="UTF-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
    <edmx:DataServices>
        <Schema Namespace="com.workflow.controller" xmlns="http://docs.oasis-open.org/odata/ns/edm">

            <ComplexType Name="ReturnOptionDTO">
                <Property Name="name" Type="Edm.String" Nullable="false"/>
                <Property Name="email" Type="Edm.String" Nullable="true"/>
                <Property Name="order" Type="Edm.Int32" Nullable="false"/>
                <Property Name="stepId" Type="Edm.String" Nullable="false"/>
                <Property Name="userId" Type="Edm.String" Nullable="false"/>
                <Property Name="position" Type="Edm.String" Nullable="true"/>
                <Property Name="department" Type="Edm.String" Nullable="true"/>
            </ComplexType>

            <ComplexType Name="ReturnOptionResponse">
                <Property Name="success" Type="Edm.Boolean" Nullable="false"/>
                <Property Name="actorRole" Type="Edm.String" Nullable="false"/>
                <Property Name="options" Type="Collection(com.workflow.controller.ReturnOptionDTO)"/>
            </ComplexType>

            <ComplexType Name="UpdateWorkflowStepRequest">
                <Property Name="statusCode" Type="Edm.String" Nullable="false"/>
                <Property Name="approverId" Type="Edm.String" Nullable="true"/>
                <Property Name="actionBy" Type="Edm.String" Nullable="true"/>
                <Property Name="comment" Type="Edm.String" Nullable="true"/>
                <Property Name="targetId" Type="Edm.String" Nullable="true"/>
                <Property Name="targetApproverId" Type="Edm.String" Nullable="true"/>
            </ComplexType>

            <ComplexType Name="UserDTO">
                <Property Name="id" Type="Edm.String" Nullable="false"/>
                <Property Name="fullName" Type="Edm.String" Nullable="false"/>
                <Property Name="role" Type="Edm.String" Nullable="false"/>
                <Property Name="status" Type="Edm.String" Nullable="false"/>
            </ComplexType>

            <Function Name="healthCheck" IsBound="false">
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Function>

            <Function Name="getFullWorkflow" IsBound="false">
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Function>

            <Function Name="getReturnOptions" IsBound="false">
                <Parameter Name="stepId" Type="Edm.String" Nullable="false"/>
                <Parameter Name="approverId" Type="Edm.String" Nullable="false"/>
                <ReturnType Type="com.workflow.controller.ReturnOptionResponse" Nullable="false"/>
            </Function>

            <Action Name="updateWorkflowStepStatus" IsBound="false">
                <Parameter Name="id" Type="Edm.String" Nullable="false"/>
                <Parameter Name="request" Type="com.workflow.controller.UpdateWorkflowStepRequest" Nullable="false"/>
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Action>

            <Function Name="getWorkflowStep" IsBound="false">
                <Parameter Name="id" Type="Edm.String" Nullable="false"/>
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Function>

            <Action Name="getValidReassignees" IsBound="false">
                <Parameter Name="current_approver_id" Type="Edm.String" Nullable="false"/>
                <Parameter Name="current_role" Type="Edm.String" Nullable="false"/>
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Action>

            <Function Name="getPRHistorySteps" IsBound="false">
                <Parameter Name="id" Type="Edm.String" Nullable="false"/>
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Function>

            <Function Name="getPRDetail" IsBound="false">
                <Parameter Name="id" Type="Edm.String" Nullable="false"/>
                <ReturnType Type="Edm.String" Nullable="false"/>
            </Function>

            <EntityContainer Name="WorkflowControllerContainer">
                
                <FunctionImport Name="HealthCheck" Function="com.workflow.controller.healthCheck" IncludeInServiceDocument="true"/>

                <FunctionImport Name="wfstep" Function="com.workflow.controller.getFullWorkflow" IncludeInServiceDocument="false"/>

                <FunctionImport Name="api/workflow/return-options" Function="com.workflow.controller.getReturnOptions" IncludeInServiceDocument="true"/>

                <ActionImport Name="api/workflow/WorkflowSteps" Action="com.workflow.controller.updateWorkflowStepStatus"/>

                <FunctionImport Name="api/workflow/WorkflowSteps" Function="com.workflow.controller.getWorkflowStep" IncludeInServiceDocument="true"/>

                <ActionImport Name="api/workflow/get-valid-reassignees" Action="com.workflow.controller.getValidReassignees"/>

                <FunctionImport Name="api/pr/history-steps" Function="com.workflow.controller.getPRHistorySteps" IncludeInServiceDocument="true"/>

                <FunctionImport Name="api/pr" Function="com.workflow.controller.getPRDetail" IncludeInServiceDocument="true"/>

            </EntityContainer>

        </Schema>
    </edmx:DataServices>
</edmx:Edmx>